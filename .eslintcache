ningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"40"},{"filePath":"65","messages":"66","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"67","messages":"68","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"69","messages":"70","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"40"},{"filePath":"71","messages":"72","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"40"},{"filePath":"73","messages":"74","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"75","messages":"76","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"77","messages":"78","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\index.js",[],["79","80"],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\Context.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\App.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\data.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Navbar.js",["81"],"import React from 'react'\r\nimport {Link} from 'react-router-dom'\r\nimport styled from 'styled-components'\r\nimport ButtonNavbar from './ButtonNavbar'\r\nimport logo from '../logo.png'\r\nclass Navbar extends React.Component{\r\n    render(){\r\n        \r\n        return(\r\n            <NavWrapper className=\"navbar navbar-expand-sm  px-sm-5\">\r\n                <Link to=\"/\">\r\n                    <img src={logo} className=\"navbar-brand\"/>\r\n                </Link>\r\n                <ul className=\"navbar-nav align-items-center ms-5 \">\r\n                    <li className=\"nav-item\">\r\n                        <Link to=\"/\" className=\"nav-link\">product</Link>\r\n                    </li>\r\n                </ul>\r\n\r\n                <Link to=\"/cart\" className=\"ms-auto\">\r\n                    <ButtonNavbar >\r\n                        <i className=\"fa fa-shopping-cart\"/>\r\n                        my cart\r\n                    </ButtonNavbar>\r\n                </Link>\r\n\r\n            </NavWrapper>\r\n              \r\n\r\n\r\n        )\r\n    }\r\n}\r\nconst NavWrapper = styled.nav`\r\nbackground:var(--mainBlue);\r\n.nav-link{\r\n    color:var(--mainWhite)\r\n}\r\nfont-size:1.3rem;\r\ntext-transform:capitalize;\r\n`\r\n\r\nexport default Navbar;","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Default.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Details.js",["82","83"],"import React from 'react'\r\nimport {ProductConsumer} from '../Context'\r\nimport ButtonNavbar from './ButtonNavbar'\r\nimport {Link} from 'react-router-dom'\r\nclass Details extends React.Component{\r\n    render(){\r\n        return(\r\n            <ProductConsumer>\r\n                {\r\n                    (value)=>{\r\n                       const{id,company,img,info,price,title,inCart} =value.detailProducts;\r\n                       return(\r\n                           <div className=\"container py-5\">\r\n                               <div className=\"row\">\r\n                                   <div className=\"col-10 mx-auto text-center text-blue my-5 text-slanted\">\r\n                                      <h1>{title}</h1>\r\n                                   </div>\r\n                               </div>\r\n                               <div className=\"row\">\r\n                                   <div className=\"col-10 col-md-6 mx-auto my-3  \">\r\n                                       <img src={img} className=\"img-fluid\"/>\r\n                                   </div>\r\n                                   <div className=\"col-10 col-md-6 mx-auto my-3  text-capitalize\">\r\n                                       <h2>model:{title}</h2>\r\n                                       <h4 className=\"text-title text-uppercase text-muted\">made by:{company}</h4>\r\n                                       <h4 className=\"text-blue\"><strong>price:${price}</strong></h4>\r\n                                       <p className=\"text-capitalize font-weight-bold\">some info about product:</p>\r\n                                       <p className=\"text-muted lead\">{info}</p>\r\n                                       <div>\r\n                                           <Link to=\"/\">\r\n                                               <ButtonNavbar>Back To Product</ButtonNavbar>\r\n                                           </Link>\r\n                                           <ButtonNavbar card >{inCart?\"In Card\":\"Add To card\"}</ButtonNavbar>\r\n                                       </div>\r\n\r\n                                   </div>\r\n\r\n                               </div>\r\n\r\n                           </div>\r\n                       )\r\n\r\n                    }\r\n                }\r\n            </ProductConsumer>\r\n\r\n        )\r\n    }\r\n}\r\nexport default Details;","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Productlist.js",["84"],"import React from 'react'\r\nimport Title from './Title'\r\nimport {storeProducts} from '../data'\r\nimport Product from './Product'\r\nimport ProductContext,{ProductConsumer}from '../Context'\r\nclass Productlist extends React.Component{\r\n\r\n    render(){\r\n\r\n        return(\r\n            <div>\r\n                <React.Fragment>\r\n                <div className=\"py-5\" >\r\n                    <div className=\"container\">\r\n                        <Title name=\"our\" title=\"product\"/>\r\n                        <div className=\"row\">\r\n                            <ProductConsumer>\r\n                                {\r\n                                    (value)=>(\r\n                                        value.products.map((product)=>(\r\n                                            <Product key={product.id} product={product}/>\r\n                                            //console.log(product)\r\n\r\n                                        ))\r\n                                    )\r\n                                }\r\n                            </ProductConsumer>\r\n                    \r\n                            \r\n\r\n                        </div>\r\n\r\n                    </div>\r\n\r\n                </div>\r\n            </React.Fragment>\r\n            </div>\r\n\r\n        )\r\n    }\r\n}\r\nProductlist.contextType=ProductContext;\r\nexport default Productlist;","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Model.js",["85"],"import React from 'react'\r\nimport styled from 'styled-components'\r\nimport {ProductConsumer} from '../Context'\r\nimport ButtonNavbar from './ButtonNavbar'\r\nimport {Link} from 'react-router-dom'\r\nclass Model extends React.Component{\r\n    render(){\r\n        return(\r\n            <ProductConsumer>\r\n                {\r\n                    (value)=>{\r\n                        const {img,title,price}=value.modelProduct \r\n                        const{modelOpen}=value;\r\n                        if(!modelOpen){\r\n                            return null\r\n                        }\r\n                        else{\r\n                            return(\r\n                                <ModelContainer>\r\n                                    <div className=\"container\">\r\n                                        <div className=\"row\">\r\n                                            <div id=\"model\" className=\"col-8 col-md-6 col-lg-4 text-center text-capitalize mx-auto\">\r\n                                                <h4 className=\"pt-5\">item added to the cart</h4>\r\n                                                <img src={img} className=\"img-fluid\"/>\r\n                                                <h5>{title}</h5>\r\n                                                <h5 className=\"text-muted\">prixe:${price}</h5>\r\n                                                <Link to=\"/\">\r\n                                                    <ButtonNavbar onClick={()=>value.closeModel()}>\r\n                                                        Back To Store\r\n                                                    </ButtonNavbar>\r\n                                                </Link>\r\n                                                <Link to=\"/cart\">\r\n                                                    <ButtonNavbar card onClick={()=>value.closeModel()} >\r\n                                                        Go To Card\r\n                                                    </ButtonNavbar>\r\n                                                </Link>\r\n                                            </div>\r\n\r\n                                        </div>\r\n\r\n                                    </div>\r\n\r\n                                </ModelContainer>\r\n                            )\r\n                        }\r\n                    }\r\n                }\r\n            </ProductConsumer>\r\n        )\r\n    }\r\n}\r\nconst ModelContainer=styled.div`\r\nposition:fixed;\r\ntop:0;\r\nleft:0;\r\nright:0;\r\nbottom:0;\r\ndisplay:flex;\r\nalign-items:center;\r\njustify-content:center;\r\nbackground:rgba(0,0,0,0.3);\r\n#model{\r\n    background:var(--mainWhite);\r\n    border-radius:15px;\r\n\r\n}\r\n`\r\nexport default Model;","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\ButtonNavbar.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Title.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Product.js",["86","87","88"],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\Cart.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartColumns.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\EmptyCart.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartList.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartLitem.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartTotal.js",["89"],{"ruleId":"90","replacedBy":"91"},{"ruleId":"92","replacedBy":"93"},{"ruleId":"94","severity":1,"message":"95","line":12,"column":21,"nodeType":"96","endLine":12,"endColumn":63},{"ruleId":"97","severity":1,"message":"98","line":11,"column":30,"nodeType":"99","messageId":"100","endLine":11,"endColumn":32},{"ruleId":"94","severity":1,"message":"95","line":21,"column":40,"nodeType":"96","endLine":21,"endColumn":78},{"ruleId":"97","severity":1,"message":"101","line":3,"column":9,"nodeType":"99","messageId":"100","endLine":3,"endColumn":22},{"ruleId":"94","severity":1,"message":"95","line":24,"column":49,"nodeType":"96","endLine":24,"endColumn":87},{"ruleId":"97","severity":1,"message":"102","line":2,"column":8,"nodeType":"99","messageId":"100","endLine":2,"endColumn":19},{"ruleId":"97","severity":1,"message":"103","line":16,"column":35,"nodeType":"99","messageId":"100","endLine":16,"endColumn":39},{"ruleId":"94","severity":1,"message":"95","line":20,"column":33,"nodeType":"96","endLine":20,"endColumn":75},{"ruleId":"97","severity":1,"message":"104","line":2,"column":9,"nodeType":"99","messageId":"100","endLine":2,"endColumn":13},"no-native-reassign",["105"],"no-negated-in-lhs",["106"],"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","no-unused-vars","'id' is assigned a value but never used.","Identifier","unusedVar","'storeProducts' is defined but never used.","'Productlist' is defined but never used.","'cart' is assigned a value but never used.","'Link' is defined but never used.","no-global-assign","no-unsafe-negation"]