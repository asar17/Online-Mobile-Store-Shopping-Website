n            <NavWrapper className=\"navbar navbar-expand-sm  px-sm-5\">\r\n                <Link to=\"/\">\r\n                    <img src={logo} className=\"navbar-brand\"/>\r\n                </Link>\r\n                <ul className=\"navbar-nav align-items-center ms-5 \">\r\n                    <li className=\"nav-item\">\r\n                        <Link to=\"/\" className=\"nav-link\">product</Link>\r\n                    </li>\r\n                </ul>\r\n\r\n                <Link to=\"/cart\" className=\"ms-auto\">\r\n                    <ButtonNavbar >\r\n                        <i className=\"fa fa-shopping-cart\"/>\r\n                        my cart\r\n                    </ButtonNavbar>\r\n                </Link>\r\n\r\n            </NavWrapper>\r\n              \r\n\r\n\r\n        )\r\n    }\r\n}\r\nconst NavWrapper = styled.nav`\r\nbackground:var(--mainBlue);\r\n.nav-link{\r\n    color:var(--mainWhite)\r\n}\r\nfont-size:1.3rem;\r\ntext-transform:capitalize;\r\n`\r\n\r\nexport default Navbar;","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Default.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Details.js",["86","87"],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Productlist.js",["88"],"import React from 'react'\r\nimport Title from './Title'\r\nimport {storeProducts} from '../data'\r\nimport Product from './Product'\r\nimport ProductContext,{ProductConsumer}from '../Context'\r\nclass Productlist extends React.Component{\r\n\r\n    render(){\r\n\r\n        return(\r\n            <div>\r\n                <React.Fragment>\r\n                <div className=\"py-5\" >\r\n                    <div className=\"container\">\r\n                        <Title name=\"our\" title=\"product\"/>\r\n                        <div className=\"row\">\r\n                            <ProductConsumer>\r\n                                {\r\n                                    (value)=>(\r\n                                        value.products.map((product)=>(\r\n                                            <Product key={product.id} product={product}/>\r\n                                            //console.log(product)\r\n\r\n                                        ))\r\n                                    )\r\n                                }\r\n                            </ProductConsumer>\r\n                    \r\n                            \r\n\r\n                        </div>\r\n\r\n                    </div>\r\n\r\n                </div>\r\n            </React.Fragment>\r\n            </div>\r\n\r\n        )\r\n    }\r\n}\r\nProductlist.contextType=ProductContext;\r\nexport default Productlist;","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Model.js",["89"],"import React from 'react'\r\nimport styled from 'styled-components'\r\nimport {ProductConsumer} from '../Context'\r\nimport ButtonNavbar from './ButtonNavbar'\r\nimport {Link} from 'react-router-dom'\r\nclass Model extends React.Component{\r\n    render(){\r\n        return(\r\n            <ProductConsumer>\r\n                {\r\n                    (value)=>{\r\n                        const {img,title,price}=value.modelProduct \r\n                        const{modelOpen}=value;\r\n                        if(!modelOpen){\r\n                            return null\r\n                        }\r\n                        else{\r\n                            return(\r\n                                <ModelContainer>\r\n                                    <div className=\"container\">\r\n                                        <div className=\"row\">\r\n                                            <div id=\"model\" className=\"col-8 col-md-6 col-lg-4 text-center text-capitalize mx-auto\">\r\n                                                <h4 className=\"pt-5\">item added to the cart</h4>\r\n                                                <img src={img} className=\"img-fluid\"/>\r\n                                                <h5>{title}</h5>\r\n                                                <h5 className=\"text-muted\">prixe:${price}</h5>\r\n                                                <Link to=\"/\">\r\n                                                    <ButtonNavbar onClick={()=>value.closeModel()}>\r\n                                                        Back To Store\r\n                                                    </ButtonNavbar>\r\n                                                </Link>\r\n                                                <Link to=\"/cart\">\r\n                                                    <ButtonNavbar card onClick={()=>value.closeModel()} >\r\n                                                        Go To Card\r\n                                                    </ButtonNavbar>\r\n                                                </Link>\r\n                                            </div>\r\n\r\n                                        </div>\r\n\r\n                                    </div>\r\n\r\n                                </ModelContainer>\r\n                            )\r\n                        }\r\n                    }\r\n                }\r\n            </ProductConsumer>\r\n        )\r\n    }\r\n}\r\nconst ModelContainer=styled.div`\r\nposition:fixed;\r\ntop:0;\r\nleft:0;\r\nright:0;\r\nbottom:0;\r\ndisplay:flex;\r\nalign-items:center;\r\njustify-content:center;\r\nbackground:rgba(0,0,0,0.3);\r\n#model{\r\n    background:var(--mainWhite);\r\n    border-radius:15px;\r\n\r\n}\r\n`\r\nexport default Model;","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\ButtonNavbar.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Title.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\Product.js",["90","91","92"],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\Cart.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartColumns.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\EmptyCart.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartList.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartLitem.js",[],"C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\CartTotal.js",["93","94"],"import React from 'react'\r\nimport {Link} from 'react-router-dom'\r\nimport styled from 'styled-components'\r\nimport PayPal from './PayPal'\r\nfunction CartTotal({value}){\r\n    const {cartSubTotal,cartTotal,cartTax,clearCart}=value\r\n    return(\r\n        <React.Fragment>\r\n             <CartWrapper className=\"container\">\r\n                <div className=\"row bor\" > \r\n                    <div className=\"col-10 mt-2 mx-auto ml-md-auto ml-sm-5  col-sm-8 text-capitalize text-end\" >\r\n                        \r\n                            <button className=\"btn btn-outline-danger text-uppercase mb-3 px-5\"  onClick={()=>clearCart()}>clear cart</button>\r\n                        \r\n                        <h5>\r\n                            <span className=\"text-title\">sub total:</span>\r\n                            <strong>${cartSubTotal}</strong>\r\n                        </h5>\r\n                        <h5>\r\n                            <span className=\"text-title\">tax:</span>\r\n                            <strong>${cartTax}</strong>\r\n                        </h5>\r\n                        <h5>\r\n                            <span className=\"text-title\"> total:</span>\r\n                            <strong>${cartTotal}</strong>\r\n                        </h5>\r\n                    </div>\r\n                 </div>\r\n            </CartWrapper> \r\n        </React.Fragment>\r\n\r\n    )\r\n}\r\nconst CartWrapper=styled.div`\r\n\r\n`\r\nexport default CartTotal","C:\\Users\\Magic\\Desktop\\e-commerce\\src\\component\\cart\\PayPal.js",[],{"ruleId":"95","replacedBy":"96"},{"ruleId":"97","replacedBy":"98"},{"ruleId":"99","severity":1,"message":"100","line":12,"column